---
import type { Note } from "../lib/knowledge-base";
import { getSectionLabel } from "../lib/knowledge-base";

interface Props {
  note: Note;
}

const { note } = Astro.props;
---

<ul class="note-meta" role="list">
  <li class="note-meta__item" data-section={note.sectionKey}>
    {getSectionLabel(note.sectionKey)}
  </li>
  <li class="note-meta__item">{new Date(note.modifiedTime).toLocaleDateString("zh-CN")}</li>
  <li class="note-meta__item">{note.isIndexedPublicly ? "公开索引" : "仅直链可见"}</li>
</ul>
