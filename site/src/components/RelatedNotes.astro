---
import type { LinkedNote } from "../lib/knowledge-base";
import { getSectionLabel } from "../lib/knowledge-base";
import { withBasePath } from "../lib/url";

interface Props {
  title: string;
  notes: LinkedNote[];
}

const { title, notes } = Astro.props;
---

{
  notes.length > 0 && (
    <section class="link-panel">
      <div class="link-panel__topline">
        <h2>{title}</h2>
        <span>{notes.length}</span>
      </div>
      <ul>
        {notes.map((note) => (
          <li>
            <a class="related-note" data-section={note.sectionKey} href={withBasePath(note.url)}>
              <span class="related-note__section">{getSectionLabel(note.sectionKey)}</span>
              <strong>{note.title}</strong>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
